# Grab a free access key at https://web3forms.com
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key-here

# Google Search Console "HTML tag" verification token.
# In GSC → Property → Settings → Ownership verification → HTML tag, copy
# the value out of <meta name="google-site-verification" content="...">.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

